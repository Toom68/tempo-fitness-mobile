# =============================================
# Supabase Configuration (REQUIRED)
# =============================================
# 1. Create a project at https://supabase.com
# 2. Go to Settings > API to find your Project URL and anon key
# 3. Copy this file to .env.local and fill in the values
# 4. Run the SQL migrations in supabase/migrations/ via the Supabase SQL Editor

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================
# Netlify Deploy Settings
# =============================================
# Set these in Netlify Dashboard → Site Settings → Environment Variables
# (they are also in netlify.toml as defaults, but dashboard overrides take priority)

# Your Netlify site URL (used for auth redirects)
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app

# =============================================
# Supabase Auth Redirect URL
# =============================================
# In Supabase Dashboard → Authentication → URL Configuration:
# - Site URL: https://your-site.netlify.app
# - Redirect URLs: https://your-site.netlify.app/auth/callback
